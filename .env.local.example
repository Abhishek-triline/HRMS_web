# Nexora HRMS — web (Next.js) env template.
#
# Copy to .env.local and adjust if your API runs on a different host/port.
# Only NEXT_PUBLIC_* vars belong here — anything else is ignored on the web side
# and should live in apps/api/.env instead.
#
# Loaded automatically by next dev / next build. Gitignored under .env.local.

NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
